
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile in the Ummy app.",
      "properties": {
        "id": { "type": "string" },
        "specialId": { "type": "string", "description": "Unique sequential numeric ID starting 001." },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "wallet": {
          "type": "object",
          "properties": {
            "coins": { "type": "number" },
            "diamonds": { "type": "number" },
            "totalSpent": { "type": "number" },
            "dailySpent": { "type": "number" }
          }
        },
        "inventory": {
          "type": "object",
          "properties": {
            "activeFrame": { "type": "string" },
            "activeBubble": { "type": "string" },
            "activeWave": { "type": "string" },
            "ownedItems": { "type": "array", "items": { "type": "string" } }
          }
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "stats": {
          "type": "object",
          "properties": {
            "followers": { "type": "number" },
            "fans": { "type": "number" },
            "dailyFans": { "type": "number" },
            "dailyGameWins": { "type": "number" }
          }
        },
        "isNewUser": { "type": "boolean" },
        "lastMoneyTreeClaimAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatRoom": {
      "title": "ChatRoom",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "roomNumber": { "type": "string" },
        "ownerId": { "type": "string" },
        "moderatorIds": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "lockedSeats": { "type": "array", "items": { "type": "number" } },
        "participantCount": { "type": "number" },
        "isChatMuted": { "type": "boolean" },
        "announcement": { "type": "string" },
        "welcomeMessage": { "type": "string" },
        "theme": { "type": "string" },
        "isLocked": { "type": "boolean" },
        "currentMusicUrl": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "totalGifts": { "type": "number" },
            "dailyGifts": { "type": "number" }
          }
        }
      }
    },
    "FollowedRoom": {
      "title": "FollowedRoom",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "roomName": { "type": "string" },
        "coverUrl": { "type": "string" },
        "followedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Game": {
      "title": "Game",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "coverUrl": { "type": "string" },
        "cost": { "type": "number" },
        "imageHint": { "type": "string" }
      }
    },
    "Moment": {
      "title": "Moment",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" }
    },
    "/users/{userId}/followingRooms/{roomId}": {
      "schema": { "$ref": "#/backend/entities/FollowedRoom" },
      "description": "Frequencies followed by the user."
    },
    "/chatRooms/{roomId}": {
      "schema": { "$ref": "#/backend/entities/ChatRoom" }
    }
  }
}
