
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile in the Ummy app.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "wallet": {
          "type": "object",
          "properties": {
            "coins": { "type": "number" },
            "diamonds": { "type": "number" },
            "totalSpent": { "type": "number" }
          }
        },
        "inventory": {
          "type": "object",
          "properties": {
            "activeFrame": { "type": "string" },
            "activeBubble": { "type": "string" },
            "ownedItems": { "type": "array", "items": { "type": "string" } }
          }
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "stats": {
          "type": "object",
          "properties": {
            "followers": { "type": "number" },
            "fans": { "type": "number" }
          }
        },
        "level": {
          "type": "object",
          "properties": {
            "rich": { "type": "number" },
            "charm": { "type": "number" }
          }
        }
      }
    },
    "AppConfig": {
      "title": "AppConfig",
      "type": "object",
      "properties": {
        "economyEnabled": { "type": "boolean" },
        "maintenanceMode": { "type": "boolean" },
        "activeBanners": { "type": "array", "items": { "$ref": "#/backend/entities/Banner" } }
      }
    },
    "Banner": {
      "title": "Banner",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "AdminLog": {
      "title": "AdminLog",
      "type": "object",
      "description": "Audit log for admin actions.",
      "properties": {
        "adminId": { "type": "string" },
        "targetId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["adminId", "action", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/appConfig/global",
        "definition": {
          "entityName": "AppConfig",
          "schema": { "$ref": "#/backend/entities/AppConfig" },
          "description": "Global application settings."
        }
      },
      {
        "path": "/users/{userId}/profile/{profileId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profile data."
        }
      },
      {
        "path": "/adminLogs/{logId}",
        "definition": {
          "entityName": "AdminLog",
          "schema": { "$ref": "#/backend/entities/AdminLog" },
          "description": "Audit trails for admin operations."
        }
      }
    ]
  }
}
