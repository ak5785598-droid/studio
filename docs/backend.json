
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile in the Ummy app.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "wallet": {
          "type": "object",
          "properties": {
            "coins": { "type": "number" },
            "diamonds": { "type": "number" }
          }
        },
        "inventory": {
          "type": "object",
          "properties": {
            "activeFrame": { "type": "string" },
            "activeBubble": { "type": "string" },
            "activeWave": { "type": "string" },
            "ownedItems": { "type": "array", "items": { "type": "string" } }
          }
        },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "AppConfig": {
      "title": "AppConfig",
      "type": "object",
      "properties": {
        "economyEnabled": { "type": "boolean" },
        "maintenanceMode": { "type": "boolean" },
        "activeBanners": { "type": "array", "items": { "$ref": "#/backend/entities/Banner" } }
      }
    },
    "Banner": {
      "title": "Banner",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "StoreItem": {
      "title": "StoreItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["Frame", "Bubble", "Wave", "Entry"] },
        "previewUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/appConfig/global",
        "definition": {
          "entityName": "AppConfig",
          "schema": { "$ref": "#/backend/entities/AppConfig" },
          "description": "Global application settings controlled by the Owner/Official."
        }
      },
      {
        "path": "/users/{userId}/profile/{profileId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profile with inventory and wallet."
        }
      },
      {
        "path": "/storeItems/{itemId}",
        "definition": {
          "entityName": "StoreItem",
          "schema": { "$ref": "#/backend/entities/StoreItem" },
          "description": "Items available in the virtual store."
        }
      }
    ]
  }
}
