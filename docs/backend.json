
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile in the Ummy app.",
      "properties": {
        "id": { "type": "string" },
        "specialId": { "type": "string", "description": "Unique 6-digit numeric ID." },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "wallet": {
          "type": "object",
          "properties": {
            "coins": { "type": "number" },
            "diamonds": { "type": "number" },
            "totalSpent": { "type": "number" },
            "dailySpent": { "type": "number" }
          }
        },
        "inventory": {
          "type": "object",
          "properties": {
            "activeFrame": { "type": "string" },
            "activeBubble": { "type": "string" },
            "ownedItems": { "type": "array", "items": { "type": "string" } }
          }
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "stats": {
          "type": "object",
          "properties": {
            "followers": { "type": "number" },
            "fans": { "type": "number" },
            "dailyFans": { "type": "number", "description": "Fans received in the current IST cycle." }
          }
        }
      }
    },
    "ChatRoom": {
      "title": "ChatRoom",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "roomNumber": { "type": "string" },
        "ownerId": { "type": "string" },
        "category": { "type": "string" },
        "lockedSeats": { "type": "array", "items": { "type": "number" } },
        "stats": {
          "type": "object",
          "properties": {
            "totalGifts": { "type": "number" },
            "dailyGifts": { "type": "number", "description": "Gifts received in the current IST cycle." }
          }
        }
      }
    },
    "Game": {
      "title": "Game",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "coverUrl": { "type": "string" },
        "cost": { "type": "number" },
        "imageHint": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User root identity."
        }
      },
      {
        "path": "/chatRooms/{roomId}",
        "definition": {
          "entityName": "ChatRoom",
          "schema": { "$ref": "#/backend/entities/ChatRoom" },
          "description": "Voice room metadata."
        }
      },
      {
        "path": "/games/{gameId}",
        "definition": {
          "entityName": "Game",
          "schema": { "$ref": "#/backend/entities/Game" },
          "description": "Dynamic game registry."
        }
      }
    ]
  }
}
