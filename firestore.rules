/**
 * Standard Security Rules for Ummy
 * Optimized for real-time chat and administrative actions.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description   User Profile Rules
     */
    match /users/{userId}/profile/{profileId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description   Chat Room Rules
     */
    match /chatRooms/{chatRoomId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.moderatorIds || chatRoomId == 'mumbai-adda');
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || chatRoomId == 'mumbai-adda');
      
      /**
       * @description   Message Rules
       */
      match /messages/{chatMessageId} {
        allow read, list: if isSignedIn();
        // Allow anyone to create messages if they are signed in
        allow create: if isSignedIn();
        // Allow owners/moderators to delete any message
        allow delete: if isSignedIn();
        allow update: if isSignedIn() && (resource.data.senderId == request.auth.uid);
      }
    }
    
    match /friendRequests/{friendRequestId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }
    
    match /userGifts/{userGiftId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /gifts/{giftId} {
      allow read, list: if isSignedIn();
    }
    
    match /tags/{tagId} {
      allow read, list: if isSignedIn();
    }
  }
}
