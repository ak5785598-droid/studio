
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    // Check if the user has an Admin or Official tag
    // Note: We check the top-level user doc for efficiency in rules
    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tags.hasAny(['Admin', 'Official'])
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      match /profile/{profileId} {
        allow read: if isSignedIn();
        allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      }
    }

    match /appConfig/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Audit logs are immutable
    }

    match /chatRooms/{chatRoomId} {
      allow read, list, create, update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      
      match /participants/{participantId} {
        allow read, list, create, update, delete: if isSignedIn();
      }
      match /messages/{messageId} {
        allow read, list, create: if isSignedIn();
        allow delete: if isAdmin();
      }
    }

    match /storeItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
