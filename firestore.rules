rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() {
      return isSignedIn() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tags', []).hasAny(['Admin', 'Official']));
    }

    function isRoomAdmin(roomId) {
      let roomPath = /databases/$(database)/documents/chatRooms/$(roomId);
      return isSignedIn() && (
        (exists(roomPath) && (
          get(roomPath).data.ownerId == request.auth.uid || 
          request.auth.uid in get(roomPath).data.get('moderatorIds', [])
        )) || isAdmin()
      );
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'wallet', 'updatedAt', 'lastSignInAt', 'inventory', 'level'])
      );
      
      match /profile/{profileId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow update: if isSignedIn() && request.auth.uid == userId;
      }
      match /notifications/{id} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn();
      }
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
      match /following/{followingId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
      match /diamondExchanges/{id} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /appConfig/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && (id == 'counters'));
    }

    match /games/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /chatRooms/{roomId} {
      allow read, list, create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.ownerId ||
        request.auth.uid in resource.data.get('moderatorIds', []) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantCount', 'stats', 'updatedAt', 'currentMusicUrl', 'lockedSeats', 'isChatMuted', 'coverUrl', 'announcement']) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /participants/{userId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && (
          request.auth.uid == userId || 
          isRoomAdmin(roomId)
        );
        
        match /signaling/{signalId} {
          allow read, write: if isSignedIn();
        }
      }
      match /messages/{id} {
        allow read, list, create: if isSignedIn();
        allow delete: if isSignedIn() && isRoomAdmin(roomId);
      }
    }

    match /moments/{momentId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }
    
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
  }
}