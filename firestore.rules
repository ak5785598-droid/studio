rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }
    
    function isCreator() {
      return isSignedIn() && request.auth.uid == '901piBzTQ0VzCtAvlyyobwvAaTs1';
    }

    function isAdmin() {
      // High-fidelity authority check via tribal summary profile
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && (
        user.tags.hasAny(['Admin', 'Official', 'Super Admin', 'Admin Management', 'App Manager']) || 
        isCreator()
      );
    }

    function isRoomAdmin(chatRoomId) {
      let room = get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data;
      return isSignedIn() && (request.auth.uid == room.ownerId || (room.moderatorIds != null && request.auth.uid in room.moderatorIds) || isAdmin());
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      
      // Only the Creator can modify tags or specialId. Owners can modify other profile data.
      allow update: if isCreator() || (
        isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['tags', 'specialId', 'wallet'])
      ) || (
        isAdmin() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['wallet', 'updatedAt'])
      );
      
      allow delete: if isAdmin();

      match /profile/{profileId} {
        allow get: if isSignedIn();
        allow write: if isOwner(userId) || isAdmin() || isCreator();
      }
      
      match /notifications/{notifId} {
        allow get, list, write: if isOwner(userId) || isAdmin() || isCreator();
      }

      match /followingRooms/{roomId} {
        allow get, list, write: if isOwner(userId);
      }
      
      match /diamondExchanges/{exchangeId} {
        allow get, list, write: if isOwner(userId);
      }
    }

    match /chatRooms/{chatRoomId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || chatRoomId == 'ummy-help-center');
      
      allow update: if isSignedIn() && (
        isOwner(resource.data.ownerId) || 
        (resource.data.moderatorIds != null && request.auth.uid in resource.data.moderatorIds) ||
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['participantCount', 'updatedAt', 'isChatMuted', 'currentMusicUrl', 'roomThemeId', 'maxActiveMics']) ||
        chatRoomId == 'ummy-help-center' ||
        isAdmin()
      );
      
      allow delete: if isExistingOwner(resource.data.ownerId) || isAdmin();

      match /participants/{participantId} {
        allow get, list: if isSignedIn();
        allow write: if isSignedIn() && (
          request.auth.uid == participantId || 
          isRoomAdmin(chatRoomId)
        );
        
        match /signaling/{signalId} {
          allow get, list, write: if isSignedIn();
        }
      }

      match /messages/{messageId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isRoomAdmin(chatRoomId);
      }
    }

    match /privateChats/{chatId} {
      allow list: if isSignedIn(); 
      allow get: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participantIds;
      }
    }

    match /roomThemes/{themeId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /moments/{momentId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /appConfig/{configId} {
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /adminLogs/{logId} {
      allow get, list, create: if isAdmin();
    }
    
    match /games/{gameId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}