/**
 * Standard Security Rules for Ummy
 * Optimized for real-time chat and administrative actions.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSender(docData) {
      return isSignedIn() && request.auth.uid == docData.senderId;
    }

    /**
     * @description   User Profile Rules
     */
    match /users/{userId}/profile/{profileId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description   Chat Room Rules
     */
    match /chatRooms/{chatRoomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.moderatorIds);
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    
    /**
     * @description   Message Rules (Simplified to prevent chat errors)
     */
    match /chatRooms/{chatRoomId}/messages/{chatMessageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.chatRoomId == chatRoomId;
      allow update, delete: if isSignedIn();
    }
    
    match /friendRequests/{friendRequestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }
    
    match /userGifts/{userGiftId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /gifts/{giftId} {
      allow read: if isSignedIn();
    }
    
    match /tags/{tagId} {
      allow read: if isSignedIn();
    }
  }
}
