
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Allow the owner to change everything, or others to only update stats/wallet during gifting
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'wallet', 'updatedAt'])
      );
      
      match /profile/{profileId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == userId;
        // Same logic for the detailed profile subcollection
        allow update: if isSignedIn() && (
          request.auth.uid == userId || 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats', 'wallet', 'updatedAt'])
        );
      }
      match /notifications/{id} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn();
      }
    }

    match /appConfig/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (id == 'counters' || id == 'global');
    }

    match /chatRooms/{roomId} {
      allow read, list, create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      match /participants/{userId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
        
        match /signaling/{peerId} {
          allow read, write: if isSignedIn();
        }
      }
      match /messages/{id} {
        allow read, list, create: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }

    // Admin Logs
    match /adminLogs/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tags.hasAny(['Admin', 'Official']));
    }
  }
}
