
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/$(request.auth.uid)).data.tags.hasAny(['Admin', 'Official']); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /appConfig/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /storeItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId}/profile/{profileId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /chatRooms/{chatRoomId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.moderatorIds);
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      match /participants/{participantId} {
        allow read, list, create, update, delete: if isSignedIn();
      }
      match /messages/{messageId} {
        allow read, list, create, delete: if isSignedIn();
      }
    }
  }
}
