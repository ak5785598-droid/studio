rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    // Robust Admin Check
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tags', []).hasAny(['Admin', 'Official']);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      // Allow users to create their own identity summary
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Allow updates by the owner or an admin
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      
      match /profile/{profileId} {
        allow read: if isSignedIn();
        // User must be creating/updating their own detailed profile
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow delete: if isAdmin();
      }
    }

    match /appConfig/{configId} {
      allow read: if isSignedIn();
      // Allow users to update counters during initialization (transactional increment)
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userCounter', 'roomCounter']);
      allow write: if isAdmin();
    }
    
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /chatRooms/{chatRoomId} {
      function isRoomAdmin() {
        let roomData = get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data;
        return isAdmin() || roomData.ownerId == request.auth.uid || roomData.get('moderatorIds', []).hasAny([request.auth.uid]);
      }

      allow read, list, create: if isSignedIn();
      allow update: if isSignedIn() && isRoomAdmin();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      
      match /participants/{participantId} {
        allow read, list, create: if isSignedIn();
        allow update: if isSignedIn() && (request.auth.uid == participantId || isRoomAdmin());
        allow delete: if isSignedIn() && (request.auth.uid == participantId || isRoomAdmin());
      }
      match /messages/{messageId} {
        allow read, list, create: if isSignedIn();
        allow delete: if isSignedIn() && isRoomAdmin();
      }
    }

    match /storeItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}