
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    // Robust Admin Check: Safe evaluation even if doc is missing
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tags', []).hasAny(['Admin', 'Official']);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      // Prioritize ownership check for faster/safer evaluation
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      
      match /profile/{profileId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow delete: if isAdmin();
      }
    }

    match /appConfig/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Audit logs are immutable
    }

    match /chatRooms/{chatRoomId} {
      allow read, list, create, update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      
      function isRoomAdmin() {
        let roomData = get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data;
        return roomData.ownerId == request.auth.uid || roomData.get('moderatorIds', []).hasAny([request.auth.uid]);
      }

      match /participants/{participantId} {
        allow read, list, create, update, delete: if isSignedIn();
      }
      match /messages/{messageId} {
        allow read, list, create: if isSignedIn();
        allow delete: if isAdmin() || isRoomAdmin();
      }
    }

    match /storeItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
