
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isCreator() {
      return isSignedIn() && request.auth.uid == '901piBzTQ0VzCtAvlyyobwvAaTs1';
    }

    // Supreme Creator Protocol - Universal Sovereignty
    match /{allPaths=**} {
      allow read, write: if isCreator();
    }

    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (
        isCreator() || 
        (exists(userPath) && get(userPath).data.get('tags', []).hasAny(['Admin', 'Official', 'Super Admin', 'Admin Management', 'App Manager']))
      );
    }

    function isRoomAdmin(chatRoomId) {
      let roomPath = /databases/$(database)/documents/chatRooms/$(chatRoomId);
      return isSignedIn() && (
        isCreator() || 
        isAdmin() ||
        (exists(roomPath) && (
          request.auth.uid == get(roomPath).data.ownerId || 
          (get(roomPath).data.get('moderatorIds', []) != null && request.auth.uid in get(roomPath).data.get('moderatorIds', []))
        ))
      );
    }

    match /appConfig/counters {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      
      allow create: if isOwner(userId);
      allow update: if isCreator() || isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /profile/{profileId} {
        allow get: if true;
        allow write: if isOwner(userId) || isAdmin() || isCreator();
      }
      
      match /notifications/{notifId} {
        allow get, list, write: if isOwner(userId) || isAdmin() || isCreator();
      }

      match /followedRooms/{roomId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /chatRooms/{chatRoomId} {
      allow get, list: if true;
      
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isRoomAdmin(chatRoomId);

      match /participants/{participantId} {
        allow get, list: if true;
        allow write: if isSignedIn();
        
        match /signaling/{signalId} {
          allow get, list, write: if isSignedIn();
        }
      }

      match /messages/{messageId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isRoomAdmin(chatRoomId);
      }

      match /bans/{userId} {
        allow get: if isSignedIn() && (request.auth.uid == userId || isRoomAdmin(chatRoomId));
        allow list, write: if isRoomAdmin(chatRoomId);
      }
    }

    match /privateChats/{chatId} {
      allow create: if isSignedIn();
      allow get, list, update: if isSignedIn() && (isCreator() || resource.data.participantIds.hasAny([request.auth.uid]));

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    match /followers/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    match /moments/{momentId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }
    
    match /games/{gameId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}
