rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User profile images: Owner only write access
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Chat room images: Authenticated users write access
    match /chatRooms/{chatRoomId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Moments / Social Graph images: Owner only write access
    match /moments/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Banner assets: Supreme Creator only
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == '901piBzTQ0VzCtAvlyyobwvAaTs1');
    }

    // Game assets: Admins/Official or Creator only
    match /games/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Global fallback for supreme creator or standard read
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == '901piBzTQ0VzCtAvlyyobwvAaTs1');
    }
  }
}
