rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User profile images
    match /users/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Chat room images
    match /chatRooms/{chatRoomId}/{allPaths=**} {
      allow read;
      // Allow authenticated users to write to room storage
      // In a production app, we would verify ownership via firestore.get()
      allow write: if request.auth != null;
    }
  }
}
